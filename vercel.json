{
  "version": 2,
  "rewrites": [
    {
      "source": "/",
      "destination": "/frontend/pages/index.html"
    },
    {
      "source": "/temas",
      "destination": "/frontend/pages/temas/index.html"
    },
    {
      "source": "/temas/",
      "destination": "/frontend/pages/temas/index.html"
    },
    {
      "source": "/temas/:tema/chat",
      "destination": "/frontend/pages/temas/:tema/chat.html"
    },
    {
      "source": "/temas/:tema/chat/",
      "destination": "/frontend/pages/temas/:tema/chat.html"
    },
    {
      "source": "/temas/:tema",
      "destination": "/frontend/pages/temas/:tema/index.html"
    },
    {
      "source": "/temas/:tema/",
      "destination": "/frontend/pages/temas/:tema/index.html"
    },
    {
      "source": "/static/:path*",
      "destination": "/frontend/static/:path*"
    }
  ]
}
